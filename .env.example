BOT_TOKEN=
# Любой OpenAI-совместимый провайдер. По умолчанию — OpenRouter.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Примеры других провайдеров (раскомментируй нужный baseURL и поставь свои MODEL):
#   OpenAI:     https://api.openai.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   локальный:  http://localhost:11434/v1   (Ollama)
# Модели (slug провайдера). MODEL обязателен; MODEL_FALLBACK опционален —
# пробуется при ошибке/429 основной. Подбери под себя; список бесплатных
# моделей OpenRouter — см. README.
MODEL=
MODEL_FALLBACK=
# Температура сэмплинга (0–2): ниже = точнее/стабильнее. Для суммаризации низкая.
LLM_TEMPERATURE=0.3
# Системный промпт из файла (правка без пересборки образа). Пусто = встроенный дефолт.
# В файле — только задача/стиль/формат: защиту от prompt-инъекций код добавляет сам.
# В Docker примонтируй файл и укажи путь внутри контейнера (см. docker-compose.yml).
SYSTEM_PROMPT_FILE=
# То же для команды /article (видео → статья). Пусто = встроенный дефолт.
ARTICLE_PROMPT_FILE=
# Язык статьи: original (как в видео) или ru (переводить). Влияет на встроенный промпт;
# в своём ARTICLE_PROMPT_FILE язык задавай сам.
ARTICLE_LANG=original
# Размер куска расшифровки в символах. Маленький кусок модель разворачивает честно,
# на большом скатывается в пересказ. Уменьши, если статьи выходят слишком краткими.
ARTICLE_CHUNK_CHARS=12000
MAX_INPUT_TOKENS=200000
RATE_LIMIT_PER_MIN=5
# Сколько ссылок обрабатывать одновременно (parse + LLM). Больше = выше риск 429.
MAX_CONCURRENCY=2
# Список Telegram user ID через запятую (узнать свой — @userinfobot). Пусто = бот открыт всем.
ALLOWED_USER_IDS=
# Файл heartbeat для Docker healthcheck (должен совпадать с HEALTHCHECK в Dockerfile).
HEARTBEAT_FILE=/tmp/heartbeat
LOG_LEVEL=info
